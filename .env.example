# Postgres
PGHOST=localhost
PGPORT=5432
PGDATABASE=postgres
PGUSER=your_pg_user
PGPASSWORD=your_pg_password
PGSCHEMA=nas
POSTCODE_BOUNDARY_TABLE=postcode_boundary

# Audit
NAS_AUDIT_LOG=logs/nas_audit.log
STRICT_ENV_CHECK=true
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173,https://admin.alamat.gov.my

# Spark tuning
SPARK_DRIVER_MEMORY=6g
SPARK_EXECUTOR_MEMORY=6g
SPARK_SQL_SHUFFLE_PARTITIONS=64

# Elasticsearch
ES_URL=http://localhost:9200
ES_INDEX=nas_addresses
ES_PORT=9200

# Queue
QUEUE_BACKEND=log
QUEUE_EVENT_LOG=logs/queue/bulk_ingest_events.jsonl
QUEUE_OFFSET_FILE=logs/queue/bulk_ingest_events.offset
INGEST_EXECUTION_MODE=queue_worker
SQS_QUEUE_URL=
AWS_REGION=ap-southeast-5

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_SECURE=false
MINIO_BUCKET=nas-uploads
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Optional LLM
OPENAI_API_KEY=
