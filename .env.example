# ── POC (single EC2 + Docker Compose) ────────────────────────────────────────
# Postgres, OpenSearch, and Valkey run as local containers.
# Their connection strings are already wired in docker-compose.yml.
# You only need to fill in the sections below.

# ── Object storage (S3) ───────────────────────────────────────────────────────
# Create an S3 bucket and either:
#   (a) attach an IAM role to the EC2 instance (preferred — leave keys empty), or
#   (b) create an IAM user with S3 access and paste the keys here.
OBJECT_STORE_BUCKET=<your-s3-bucket-name>
AWS_REGION=ap-southeast-1
OBJECT_STORE_ENDPOINT=
OBJECT_STORE_PUBLIC_ENDPOINT=
OBJECT_STORE_SECURE=true
OBJECT_STORE_PUBLIC_SECURE=true
OBJECT_STORE_USE_PATH_STYLE=false
OBJECT_STORE_AUTO_CREATE_BUCKET=false
OBJECT_STORE_MANAGE_CORS=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ── Application ───────────────────────────────────────────────────────────────
# Replace with the public IP or domain of your EC2 instance.
CORS_ALLOW_ORIGINS=http://<ec2-public-ip>:8000
NAS_AUDIT_LOG=logs/nas_audit.log
STRICT_ENV_CHECK=true
STRICT_LOOKUP_DB_CHECK=true
INGEST_STALE_CLAIM_SECONDS=300
INGEST_STALE_CLAIM_RECOVERY_INTERVAL_SECONDS=30

# ── Optional LLM enrichment ───────────────────────────────────────────────────
OPENAI_API_KEY=
