# Postgres
PGHOST=localhost
# Host-side port for the Docker Postgres container.
PGPORT=5433
PGDATABASE=postgres
PGUSER=your_pg_user
PGPASSWORD=your_pg_password
PGSCHEMA=nas
POSTCODE_BOUNDARY_TABLE=postcode_boundary

# Audit
NAS_AUDIT_LOG=logs/nas_audit.log
STRICT_ENV_CHECK=true
STRICT_LOOKUP_DB_CHECK=true
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173,https://admin.alamat.gov.my

# Spark tuning
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=2g
SPARK_SQL_SHUFFLE_PARTITIONS=16

# Elasticsearch
ES_URL=http://localhost:9200
ES_INDEX=nas_addresses
ES_PORT=9200

# Queue
QUEUE_BACKEND=redis_stream
QUEUE_EVENT_LOG=logs/queue/bulk_ingest_events.jsonl
QUEUE_OFFSET_FILE=logs/queue/bulk_ingest_events.offset
INGEST_EXECUTION_MODE=queue_worker
INGEST_STALE_CLAIM_SECONDS=300
INGEST_STALE_CLAIM_RECOVERY_INTERVAL_SECONDS=30
SQS_QUEUE_URL=
AWS_REGION=ap-southeast-5
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_KEY=bulk_ingest_events
REDIS_STREAM_GROUP=bulk_ingest_workers
REDIS_STREAM_BLOCK_MS=5000
REDIS_STREAM_CLAIM_IDLE_MS=60000
REDIS_STREAM_CLAIM_COUNT=10

# Object storage (AWS S3 or any S3-compatible service)
OBJECT_STORE_BUCKET=nas-uploads
OBJECT_STORE_ENDPOINT=
OBJECT_STORE_PUBLIC_ENDPOINT=
OBJECT_STORE_SECURE=true
OBJECT_STORE_PUBLIC_SECURE=true
OBJECT_STORE_USE_PATH_STYLE=false
OBJECT_STORE_AUTO_CREATE_BUCKET=false
OBJECT_STORE_MANAGE_CORS=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Local MinIO compatibility for development
MINIO_ENDPOINT=localhost:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_SECURE=false
MINIO_BUCKET=nas-uploads
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Optional LLM
OPENAI_API_KEY=
